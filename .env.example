# ─────────────────────────────────────────────────────────────
# Pizza House — Monorepo Environment Variables
# Copy this file to .env and fill in your values.
# The root .env is NOT used at runtime — see notes below.
# ─────────────────────────────────────────────────────────────

# ── SERVER (apps/server/.env) ──────────────────────────────
# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/<db>?retryWrites=true&w=majority

# JWT secret (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret

# Port for NestJS
PORT=5000

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# ── CLIENT (apps/client/.env.local) ────────────────────────
# Server-side only — not exposed to browser
API_URL=http://localhost:5000

# Exposed to browser (client components)
NEXT_PUBLIC_API_URL=http://localhost:5000
